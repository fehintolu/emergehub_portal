<!DOCTYPE html>
<html><head><meta charset="utf-8"><title>Receipt <%= p.receipt_number %></title>
<link rel="stylesheet" href="/css/portal.css" /></head>
<body class="portal-body" style="padding:2rem;">
  <h1>Payment receipt</h1>
  <p>Receipt: <strong><%= p.receipt_number %></strong></p>
  <p>Invoice: <%= p.invoice_number %></p>
  <p>Amount: <%= formatNgn(p.amount_cents) %></p>
  <p>Method: <%= p.method %></p>
  <p>Date: <%= formatDateTime(p.created_at) %></p>
  <p><button class="btn btn-primary" onclick="window.print()">Print</button></p>
</body></html>
