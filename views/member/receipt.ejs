<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Receipt <%= p.receipt_number %></title>
  <link rel="stylesheet" href="/css/member-portal.css?v=<%= memberPortalCssV %>" />
</head>
<body style="padding:2rem;background:var(--bg);font-family:var(--font);color:var(--text);">
  <div class="card" style="max-width:520px;">
    <h1 class="page-title">Payment receipt</h1>
    <p>Receipt: <strong><%= p.receipt_number %></strong></p>
    <p>Invoice: <%= p.invoice_number %></p>
    <p>Amount: <%= formatNgn(p.amount_cents) %></p>
    <p>Method: <%= p.method %></p>
    <p>Date: <%= formatDateTime(p.created_at) %></p>
    <p style="margin-top:20px;"><button type="button" class="btn btn-primary" onclick="window.print()">Print</button></p>
  </div>
</body>
</html>
