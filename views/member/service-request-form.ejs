<h2 class="page-title">Request: <%= service.name %></h2>
<p class="page-lead">Category: <%= service.category_name %></p>
<% var _pc = Number(service.portal_price_cents || 0); %>
<% if (_pc > 0) { %>
  <div class="card" style="margin-bottom:16px;">
    <p style="margin:0;font-size:15px;">Quoted fee: <strong><%= formatNgn(_pc) %></strong></p>
    <p class="page-lead" style="margin:8px 0 0;">After you submit, an invoice will be created and you can pay from this request or Billing.</p>
  </div>
<% } else { %>
  <p class="page-lead">No fixed fee on this service — our team will confirm pricing if needed.</p>
<% } %>
<% if (typeof query !== 'undefined' && query.err === 'upload') { %>
  <div class="alert alert-error">File upload failed validation.</div>
<% } %>
<div class="card">
  <form method="post" action="/services/request/<%= service.id %>" enctype="multipart/form-data">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
    <div class="form-row">
      <label>Describe your requirement</label>
      <textarea name="description" required></textarea>
    </div>
    <div class="form-row">
      <label>Additional details</label>
      <textarea name="extra_details" placeholder="CAC details, virtual office needs, etc."></textarea>
    </div>
    <div class="form-row">
      <label>Attachment (optional, PDF/JPG/PNG/DOCX, max 10MB)</label>
      <input type="file" name="attachment" accept=".pdf,.jpg,.jpeg,.png,.docx" />
    </div>
    <button type="submit" class="btn btn-primary">Submit request</button>
  </form>
</div>
