<div class="tabs">
  <a href="/settings/profile" class="<%= tab === 'profile' ? 'is-active' : '' %>">Profile</a>
  <a href="/settings/business" class="<%= tab === 'business' ? 'is-active' : '' %>">Business</a>
  <a href="/settings/notifications" class="<%= tab === 'notifications' ? 'is-active' : '' %>">Notifications</a>
  <a href="/settings/security" class="<%= tab === 'security' ? 'is-active' : '' %>">Security</a>
</div>

<div class="card">
<% if (tab === 'profile') { %>
  <form method="post" action="/settings/profile" enctype="multipart/form-data">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
    <div class="form-row"><label>Full name</label><input type="text" name="full_name" value="<%= currentMember.full_name %>" required /></div>
    <div class="form-row"><label>Email</label><input type="email" name="email" value="<%= currentMember.email %>" required /></div>
    <div class="form-row"><label>Phone</label><input type="tel" name="phone" value="<%= currentMember.phone %>" required /></div>
    <div class="form-row"><label>Profile photo (JPG/PNG)</label><input type="file" name="photo" accept=".jpg,.jpeg,.png" /></div>
    <button type="submit" class="btn btn-primary">Save</button>
  </form>
  <p style="margin-top:16px;"><small style="color:var(--text-secondary);">Changing email will require re-verification.</small></p>
<% } %>

<% if (tab === 'business') { %>
  <form method="post" action="/settings/business">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
    <div class="form-row"><label>Business name</label><input type="text" name="business_name" value="<%= currentMember.business_name || '' %>" /></div>
    <div class="form-row"><label>Business type</label><input type="text" name="business_type" value="<%= currentMember.business_type || '' %>" /></div>
    <div class="form-row"><label>CAC number</label><input type="text" name="cac_number" value="<%= currentMember.cac_number || '' %>" /></div>
    <div class="form-row"><label>Industry</label><input type="text" name="industry" value="<%= currentMember.industry || '' %>" /></div>
    <div class="form-row"><label>Website</label><input type="url" name="website" value="<%= currentMember.website || '' %>" /></div>
    <button type="submit" class="btn btn-primary">Save</button>
  </form>
<% } %>

<% if (tab === 'notifications') { %>
  <form method="post" action="/settings/notifications">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
    <div class="form-row" style="margin-bottom:12px;"><label><input type="checkbox" name="notify_email_invoice" value="1" <%= currentMember.notify_email_invoice ? 'checked' : '' %> /> Invoice emails</label></div>
    <div class="form-row" style="margin-bottom:12px;"><label><input type="checkbox" name="notify_email_service" value="1" <%= currentMember.notify_email_service ? 'checked' : '' %> /> Service updates</label></div>
    <div class="form-row" style="margin-bottom:12px;"><label><input type="checkbox" name="notify_email_support" value="1" <%= currentMember.notify_email_support ? 'checked' : '' %> /> Support replies</label></div>
    <div class="form-row" style="margin-bottom:12px;"><label><input type="checkbox" name="notify_email_announcements" value="1" <%= currentMember.notify_email_announcements ? 'checked' : '' %> /> Announcements</label></div>
    <div class="form-row" style="margin-bottom:12px;"><label><input type="checkbox" name="notify_sms" value="1" <%= currentMember.notify_sms ? 'checked' : '' %> /> SMS (if phone verified)</label></div>
    <button type="submit" class="btn btn-primary" style="margin-top:8px;">Save</button>
  </form>
<% } %>

<% if (tab === 'security') { %>
  <form method="post" action="/settings/password">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
    <div class="form-row"><label>Current password</label><input type="password" name="current_password" required autocomplete="current-password" /></div>
    <div class="form-row"><label>New password</label><input type="password" name="password" minlength="8" required autocomplete="new-password" /></div>
    <div class="form-row"><label>Confirm</label><input type="password" name="password2" minlength="8" required autocomplete="new-password" /></div>
    <button type="submit" class="btn btn-primary">Update password</button>
  </form>
  <h3 style="margin:28px 0 12px;">Active sessions</h3>
  <ul class="plain-list">
    <% sessions.forEach(function (s) { %>
      <li>
        <%= s.ip_address %> · <%= formatDateTime(s.last_seen_at) %>
        <form method="post" action="/settings/session-revoke" style="display:inline;margin-left:8px;">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <input type="hidden" name="session_sid" value="<%= s.session_sid %>" />
          <button type="submit" class="link-btn">Log out</button>
        </form>
      </li>
    <% }); %>
  </ul>
<% } %>
</div>
