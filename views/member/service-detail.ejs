<% if (sr.action_required_member) { %>
  <div class="alert alert-error" style="border-left:4px solid var(--accent);">
    <strong>Action required</strong> — please check messages below or upload requested documents.
  </div>
<% } %>
<% if (sr.service_start_date && sr.service_end_date) { %>
  <div class="card anim anim-2" style="border-left:4px solid var(--accent);margin-bottom:16px;">
    <h3 class="page-title" style="margin:0 0 8px;font-size:1.05rem;">Service period</h3>
    <p class="page-lead" style="margin:0;">Your agreed service runs from <strong><%= formatDate(sr.service_start_date) %></strong> to <strong><%= formatDate(sr.service_end_date) %></strong>.</p>
  </div>
<% } %>
<% if (typeof bookingPlan !== 'undefined' && bookingPlan) { %>
  <% var _dv = Number(bookingPlan.duration_value); var _du = String(bookingPlan.duration_unit || '').toLowerCase(); %>
  <% var _durOk = _dv > 0 && ['hour','day','month'].includes(_du); %>
  <% if (_durOk && sr.access_started_at) { %>
    <div class="card anim anim-2" style="border-left:4px solid var(--green);margin-bottom:16px;">
      <h3 class="page-title" style="margin:0 0 8px;font-size:1.05rem;">Your access</h3>
      <p class="page-lead" style="margin:0;">From <strong><%= formatDateTime(sr.access_started_at) %></strong> to <strong><%= formatDateTime(sr.access_ends_at) %></strong>.</p>
    </div>
  <% } else if (_durOk && !sr.access_started_at) { %>
    <div class="card anim anim-2" style="margin-bottom:16px;">
      <p class="page-lead" style="margin:0;">This booking includes <strong><%= _dv %></strong> <%= _du === 'month' ? (_dv === 1 ? 'month' : 'months') : _du === 'day' ? (_dv === 1 ? 'day' : 'days') : (_dv === 1 ? 'hour' : 'hours') %> of access. Your access window will appear here once payment is confirmed.</p>
    </div>
  <% } %>
<% } %>
<% if (typeof invoicesWithItems !== 'undefined' && invoicesWithItems.length) { %>
  <% invoicesWithItems.forEach(function (pack) { var invoice = pack.invoice; var invoiceItems = pack.items; %>
    <div class="card anim anim-2" style="border-left:4px solid var(--accent);margin-bottom:20px;">
      <div class="section-header" style="margin-top:0;">
        <span class="section-title">Invoice</span>
      </div>
      <p style="margin:8px 0 4px;"><strong><%= invoice.invoice_number %></strong> · <%= formatNgn(invoice.total_cents) %></p>
      <p class="page-lead" style="margin:0 0 12px;">Due <%= formatDate(invoice.due_date) %> · <span class="badge"><%= invoice.status %></span>
        · <a href="/billing/invoices/<%= invoice.id %>/print" target="_blank" rel="noopener">Print</a></p>
      <% if (invoiceItems && invoiceItems.length) { %>
        <ul class="plain-list" style="margin-bottom:12px;">
          <% invoiceItems.forEach(function (it) { %>
            <li><%= it.description %> — <strong><%= formatNgn(it.amount_cents) %></strong></li>
          <% }); %>
        </ul>
      <% } %>
      <% if (['unpaid','sent','overdue'].includes(invoice.status)) { %>
        <p class="page-lead" style="margin-bottom:12px;">Pay online from <a href="/billing" class="section-link">Billing</a>, or use the bank details below and upload proof from Billing.</p>
        <button type="button" class="btn btn-primary pay-now-sr" data-invoice="<%= invoice.id %>">Pay now</button>
      <% } %>
      <% if (invoice.status === 'awaiting_confirmation') { %>
        <p class="page-lead" style="margin:0;"><em>Payment proof received — awaiting confirmation.</em></p>
      <% } %>
    </div>
  <% }); %>
  <div class="card anim anim-2" style="margin-bottom:20px;">
    <div class="section-header" style="margin-top:0;">
      <span class="section-title">Bank transfer</span>
    </div>
    <p><strong><%= bankName || '—' %></strong></p>
    <p>Account name: <%= accountName || '—' %></p>
    <p>Account number: <%= accountNumber || '—' %></p>
    <p class="page-lead" style="margin-top:12px;margin-bottom:0;">Use your invoice number as the payment reference where possible.</p>
  </div>
  <script>
  (function () {
    document.querySelectorAll('.pay-now-sr').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var invoiceId = btn.getAttribute('data-invoice');
        fetch('/billing/pay/init', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: '_csrf=' + encodeURIComponent(<%- JSON.stringify(csrfToken) %>) + '&invoice_id=' + encodeURIComponent(invoiceId),
          credentials: 'same-origin'
        }).then(function (r) { return r.json(); }).then(function (data) {
          if (data.error) { alert(data.error); return; }
          if (data.authorization_url) {
            window.location.href = data.authorization_url;
          } else {
            alert('Paystack did not return a checkout URL.');
          }
        }).catch(function () { alert('Could not start payment.'); });
      });
    });
  })();
  </script>
<% } %>
<h2 class="page-title" style="margin-bottom:4px;"><%= sr.service_name %></h2>
<p><span class="badge"><%= sr.status %></span> · <%= sr.category_name %></p>
<p class="page-lead" style="margin-bottom:20px;">Requested <%= formatDateTime(sr.created_at) %> · Updated <%= formatDateTime(sr.updated_at) %></p>

<div class="card">
  <h3>Timeline</h3>
  <div class="stepper">
    <% updates.forEach(function (u) { %>
      <span><%= u.stage %> · <%= formatDateTime(u.created_at) %></span>
    <% }); %>
  </div>
</div>

<div class="card">
  <h3>Updates</h3>
  <ul class="plain-list">
    <% updates.forEach(function (u) { %>
      <li><%= formatDateTime(u.created_at) %> — <strong><%= u.stage %></strong><% if (u.note) { %>: <%= u.note %><% } %></li>
    <% }); %>
  </ul>
</div>

<div class="card">
  <h3>Documents</h3>
  <% if (!docs.length) { %><p class="page-lead" style="margin:0;">None attached.</p><% } %>
  <ul class="plain-list">
    <% docs.forEach(function (d) { %>
      <li><a href="/documents/download/<%= d.id %>"><%= d.original_name %></a> · <%= formatDateTime(d.created_at) %></li>
    <% }); %>
  </ul>
</div>

<div class="card">
  <h3>Messages</h3>
  <% msgs.forEach(function (msg) { %>
    <div class="card" style="background:var(--surface-2);margin-bottom:12px;">
      <small style="color:var(--text-secondary);"><%= msg.sender_type %> · <%= formatDateTime(msg.created_at) %></small>
      <p style="margin-top:8px;"><%= msg.body %></p>
    </div>
  <% }); %>
  <form method="post" action="/services/<%= sr.id %>/message" style="margin-top:16px;">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
    <div class="form-row"><label>Message EmergeHub</label><textarea name="body" required placeholder="Message EmergeHub"></textarea></div>
    <button type="submit" class="btn btn-primary">Send message</button>
  </form>
</div>
