<% var invList = (typeof outstanding !== 'undefined' && outstanding && Array.isArray(outstanding)) ? outstanding : []; %>
<% var histList = (typeof history !== 'undefined' && history && Array.isArray(history)) ? history : []; %>
<div class="portal-page portal-page--billing">
<% if (typeof bookedBanner !== 'undefined' && bookedBanner) { %>
  <div class="portal-flash portal-flash--success">
    Meeting room booking created. Pay within 2 hours to confirm your slot.
    <% if (typeof bookingRef === 'string' && bookingRef) { %> Reference: <strong><%= bookingRef %></strong>.<% } %>
  </div>
<% } %>
<% if (typeof invoiceFocus === 'string' && invoiceFocus && !invList.some(function (i) { return String(i.id) === invoiceFocus; })) { %>
  <div class="portal-flash portal-flash--error">That invoice is not in your outstanding list (it may already be paid or cancelled).</div>
<% } %>

  <div class="portal-section-head">
    <h2 class="portal-section-title">Outstanding invoices</h2>
  </div>
<% if (!invList.length) { %>
  <div class="portal-panel portal-panel--empty">
    <p class="portal-panel-muted">None — you are up to date.</p>
  </div>
<% } %>
<% invList.forEach(function (inv) { %>
  <div class="portal-panel portal-panel--invoice<%= inv.status === 'overdue' ? ' is-overdue' : '' %><%= (typeof invoiceFocus === 'string' && invoiceFocus === String(inv.id)) ? ' is-focused' : '' %>" id="invoice-<%= inv.id %>">
    <div class="portal-invoice-head">
      <strong class="portal-invoice-num"><%= inv.invoice_number %></strong>
      <span class="portal-pill"><%= inv.status %></span>
    </div>
    <p class="portal-invoice-amount"><%= formatNgn(inv.total_cents) %> · Due <%= formatDate(inv.due_date) %></p>
    <% var ex = typeof invExtras !== 'undefined' && invExtras ? (invExtras[String(inv.id)] || invExtras[inv.id]) : null; %>
    <% if (ex && ex.links && ex.links.length) { %>
      <p class="portal-invoice-meta"><strong>Includes</strong>:
        <% ex.links.forEach(function (l, idx) { %><%= idx ? ', ' : '' %><%= l.service_name || l.sr_title || 'Service' %><% }); %>
      </p>
    <% } %>
    <% if (ex && ex.room) { %>
      <p class="portal-invoice-meta"><strong>Meeting room</strong>: <%= ex.room.room_name %> (<%= ex.room.booking_reference %>)</p>
    <% } %>
    <p class="portal-invoice-meta"><a href="/billing/invoices/<%= inv.id %>/print" target="_blank" rel="noopener" class="portal-inline-link">Print invoice</a></p>
    <% if (['unpaid','sent','overdue'].includes(inv.status)) { %>
      <button type="button" class="portal-btn-primary pay-now" data-invoice="<%= inv.id %>">Pay now</button>
      <details class="portal-details">
        <summary>I paid by bank transfer</summary>
        <form method="post" action="/billing/manual" enctype="multipart/form-data" class="portal-manual-form">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <input type="hidden" name="invoice_id" value="<%= inv.id %>" />
          <p class="portal-form-hint">Upload proof (PDF/JPG/PNG/DOCX)</p>
          <div class="form-row"><input type="file" name="proof" required accept=".pdf,.jpg,.jpeg,.png,.docx" /></div>
          <button type="submit" class="portal-btn-secondary">Submit</button>
        </form>
      </details>
    <% } %>
    <% if (inv.status === 'awaiting_confirmation') { %>
      <p class="portal-panel-muted" style="margin-top:10px;"><em>Awaiting confirmation from EmergeHub.</em></p>
    <% } %>
  </div>
<% }); %>

  <div class="portal-section-head">
    <h2 class="portal-section-title">Bank transfer</h2>
  </div>
  <div class="portal-panel">
    <p class="portal-bank-line"><strong><%= bankName || '—' %></strong></p>
    <p class="portal-bank-line">Account name: <%= accountName %></p>
    <p class="portal-bank-line">Account number: <%= accountNumber || '—' %></p>
  </div>

  <div class="portal-section-head">
    <h2 class="portal-section-title">Payment history</h2>
  </div>
  <div class="portal-table-wrap">
    <table class="portal-data-table">
      <thead><tr><th>Date</th><th>Invoice</th><th>Amount</th><th>Method</th><th>Status</th><th>Receipt</th></tr></thead>
      <tbody>
        <% histList.forEach(function (p) { %>
          <tr>
            <td><%= formatDateTime(p.created_at) %></td>
            <td><%= p.invoice_number %></td>
            <td><%= formatNgn(p.amount_cents) %></td>
            <td><%= p.method %></td>
            <td><%= p.status %></td>
            <td><% if (p.status === 'completed' && p.receipt_number) { %><a href="/billing/receipt/<%= p.id %>" class="portal-inline-link">Receipt</a><% } else { %>—<% } %></td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
</div>

<script>
(function () {
  document.querySelectorAll('.pay-now').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var invoiceId = btn.getAttribute('data-invoice');
      fetch('/billing/pay/init', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: '_csrf=' + encodeURIComponent(<%- JSON.stringify(typeof csrfToken !== 'undefined' ? csrfToken : '') %>) + '&invoice_id=' + encodeURIComponent(invoiceId),
        credentials: 'same-origin'
      }).then(function (r) { return r.json(); }).then(function (data) {
        if (data.error) { alert(data.error); return; }
        if (data.authorization_url) {
          window.location.href = data.authorization_url;
        } else {
          alert('Paystack did not return a checkout URL.');
        }
      }).catch(function () { alert('Could not start payment.'); });
    });
  });
})();
<% if (typeof invoiceFocus === 'string' && invoiceFocus) { %>
(function () {
  var el = document.getElementById('invoice-<%= invoiceFocus %>');
  if (el) el.scrollIntoView({ behavior: 'smooth', block: 'start' });
})();
<% } %>
</script>
