<div class="section-header" style="margin-top:0;">
  <span class="section-title">Outstanding invoices</span>
</div>
<% if (!outstanding.length) { %>
  <div class="activity-card" style="margin-bottom:24px;">
    <div class="activity-empty" style="padding:32px 20px;">
      <p>None — you are up to date.</p>
    </div>
  </div>
<% } %>
<% outstanding.forEach(function (inv) { %>
  <div class="card" style="<%= inv.status === 'overdue' ? 'border:2px solid #b00020;' : '' %>">
    <div style="display:flex;flex-wrap:wrap;align-items:center;gap:10px;">
      <strong><%= inv.invoice_number %></strong>
      <span class="badge"><%= inv.status %></span>
    </div>
    <p style="margin:10px 0;"><%= formatNgn(inv.total_cents) %> · Due <%= formatDate(inv.due_date) %></p>
    <% var ex = typeof invExtras !== 'undefined' && invExtras[inv.id] ? invExtras[inv.id] : null; %>
    <% if (ex && ex.links && ex.links.length) { %>
      <p style="font-size:13px;margin:0 0 8px;"><strong>Includes</strong>:
        <% ex.links.forEach(function (l, idx) { %><%= idx ? ', ' : '' %><%= l.service_name %><% }); %>
      </p>
    <% } %>
    <% if (ex && ex.room) { %>
      <p style="font-size:13px;margin:0 0 8px;"><strong>Meeting room</strong>: <%= ex.room.room_name %> (<%= ex.room.booking_reference %>)</p>
    <% } %>
    <p style="margin:0 0 8px;"><a href="/billing/invoices/<%= inv.id %>/print" target="_blank" rel="noopener">Print invoice</a></p>
    <% if (['unpaid','sent','overdue'].includes(inv.status)) { %>
      <button type="button" class="btn btn-primary pay-now" data-invoice="<%= inv.id %>">Pay now</button>
      <details style="margin-top:12px;">
        <summary style="cursor:pointer;font-weight:600;color:var(--brand);font-size:13px;">I paid by bank transfer</summary>
        <form method="post" action="/billing/manual" enctype="multipart/form-data" style="margin-top:12px;">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <input type="hidden" name="invoice_id" value="<%= inv.id %>" />
          <p class="page-lead" style="margin-bottom:8px;">Upload proof (PDF/JPG/PNG/DOCX)</p>
          <div class="form-row"><input type="file" name="proof" required accept=".pdf,.jpg,.jpeg,.png,.docx" /></div>
          <button type="submit" class="btn btn-secondary">Submit</button>
        </form>
      </details>
    <% } %>
    <% if (inv.status === 'awaiting_confirmation') { %>
      <p style="margin-top:10px;"><em>Awaiting confirmation from EmergeHub.</em></p>
    <% } %>
  </div>
<% }); %>

<div class="section-header">
  <span class="section-title">Bank transfer</span>
</div>
<div class="card">
  <p><strong><%= bankName || '—' %></strong></p>
  <p>Account name: <%= accountName %></p>
  <p>Account number: <%= accountNumber || '—' %></p>
</div>

<div class="section-header">
  <span class="section-title">Payment history</span>
</div>
<div class="table-wrap">
  <table class="data">
    <thead><tr><th>Date</th><th>Invoice</th><th>Amount</th><th>Method</th><th>Status</th><th>Receipt</th></tr></thead>
    <tbody>
      <% history.forEach(function (p) { %>
        <tr>
          <td><%= formatDateTime(p.created_at) %></td>
          <td><%= p.invoice_number %></td>
          <td><%= formatNgn(p.amount_cents) %></td>
          <td><%= p.method %></td>
          <td><%= p.status %></td>
          <td><% if (p.status === 'completed' && p.receipt_number) { %><a href="/billing/receipt/<%= p.id %>">Receipt</a><% } else { %>—<% } %></td>
        </tr>
      <% }); %>
    </tbody>
  </table>
</div>

<script>
(function () {
  document.querySelectorAll('.pay-now').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var invoiceId = btn.getAttribute('data-invoice');
      fetch('/billing/pay/init', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: '_csrf=' + encodeURIComponent(<%- JSON.stringify(csrfToken) %>) + '&invoice_id=' + encodeURIComponent(invoiceId),
        credentials: 'same-origin'
      }).then(function (r) { return r.json(); }).then(function (data) {
        if (data.error) { alert(data.error); return; }
        if (data.authorization_url) {
          window.location.href = data.authorization_url;
        } else {
          alert('Paystack did not return a checkout URL.');
        }
      }).catch(function () { alert('Could not start payment.'); });
    });
  });
})();
</script>
