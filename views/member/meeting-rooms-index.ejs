<% function mrAmenityList(r) {
  var raw = r.amenities;
  if (raw == null || raw === undefined) return ['Fast internet', 'Constant power', 'Parking'];
  try {
    var a = typeof raw === 'string' ? JSON.parse(raw) : raw;
    if (Array.isArray(a) && a.length) return a.map(function (x) { return String(x); }).slice(0, 8);
  } catch (e) {}
  return ['Fast internet', 'Constant power', 'Parking'];
} %>
<% function mrBand(r) {
  var k = String(r.room_product_kind || '').toLowerCase();
  if (k === 'training') return 'band-training';
  if (k === 'video_shoot' || k === 'video') return 'band-video';
  if (k === 'conference') return 'band-conf';
  return 'band-main';
} %>
<% function mrFilterFlags(r) {
  var k = String(r.room_product_kind || '').toLowerCase();
  return {
    meeting: (k === 'conference' || k === '') ? '1' : '0',
    training: k === 'training' ? '1' : '0',
    video: (k === 'video_shoot' || k === 'video') ? '1' : '0',
    credits: r.consumes_plan_credits ? '1' : '0',
  };
} %>
<% var chk = '<svg width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true" focusable="false"><path d="M1.5 5l2 2 4-4" stroke="#1a7a4a" stroke-width="1.5" stroke-linecap="round"/></svg>'; %>

<div class="portal-page portal-page--rooms">
<% if (!rooms.length) { %>
  <div class="portal-empty-card">
    <p>No bookable meeting rooms are configured yet. Please check back soon or contact the hub team.</p>
  </div>
<% } else { %>
  <div class="mr-filter-bar" data-mr-filters>
    <span class="mr-filter-label">Filter by:</span>
    <button type="button" class="mr-filter-chip active" data-filter="all">All rooms</button>
    <button type="button" class="mr-filter-chip" data-filter="meeting">Meeting</button>
    <button type="button" class="mr-filter-chip" data-filter="training">Training</button>
    <button type="button" class="mr-filter-chip" data-filter="video">Video shoot</button>
    <button type="button" class="mr-filter-chip" data-filter="credits">Credits accepted</button>
  </div>

  <div class="mr-rooms-grid">
    <% rooms.forEach(function (r) { %>
      <% var ff = mrFilterFlags(r); %>
      <% var hr = Number(r.hourly_rate_cents) || 0; %>
      <% var fd = Number(r.full_day_rate_cents) || 0; %>
      <% var amenities = mrAmenityList(r); %>
      <article
        class="mr-room-card"
        data-mr-card
        data-mr-match-all="1"
        data-mr-match-meeting="<%= ff.meeting %>"
        data-mr-match-training="<%= ff.training %>"
        data-mr-match-video="<%= ff.video %>"
        data-mr-match-credits="<%= ff.credits %>"
      >
        <div class="mr-room-band <%= mrBand(r) %>"></div>
        <div class="mr-room-body">
          <div class="mr-room-header">
            <div class="mr-room-icon-wrap" aria-hidden="true">
              <% var pk = String(r.room_product_kind || '').toLowerCase(); %>
              <% if (pk === 'training') { %>
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="3" width="12" height="9" rx="1.5"/><path d="M8 12v3M5 15h6"/><path d="M16 7v6"/><circle cx="16" cy="5" r="1.5"/></svg>
              <% } else if (pk === 'video_shoot' || pk === 'video') { %>
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="6" width="11" height="8" rx="2"/><path d="M13 9l5-3v8l-5-3"/></svg>
              <% } else if (pk === 'conference' && fd > 0 && hr <= 0) { %>
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="4" width="14" height="13" rx="2"/><path d="M7 2v4M13 2v4M3 9h14"/><path d="M7 13h6"/></svg>
              <% } else if (pk === 'conference') { %>
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="10" cy="10" r="7"/><path d="M10 6v4l3 2"/></svg>
              <% } else { %>
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="5" width="16" height="11" rx="2"/><path d="M6 5V4a1 1 0 0 1 1-1h6a1 1 0 0 1 1 1v1"/><path d="M7 10h6M7 13h4"/></svg>
              <% } %>
            </div>
            <div class="mr-room-badges">
              <span class="mr-badge mr-badge-capacity">
                <svg width="10" height="10" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><circle cx="5" cy="4" r="2"/><path d="M2 10c0-2 1.3-3.5 3-3.5s3 1.5 3 3.5"/><circle cx="9" cy="4" r="1.5"/><path d="M9 8.5c1.2 0 2 1 2 2.5"/></svg>
                <%= r.capacity %> people
              </span>
              <% if (r.consumes_plan_credits) { %>
              <span class="mr-badge mr-badge-credits">
                <svg width="10" height="10" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><rect x="1" y="2" width="10" height="8" rx="1.5"/><path d="M3.5 2V1M8.5 2V1M1 5h10"/></svg>
                Credits apply
              </span>
              <% } %>
            </div>
          </div>
          <h3 class="mr-room-name"><%= r.name %></h3>
          <% if (r.description) { %><div class="mr-room-desc"><%= r.description %></div><% } %>
          <div class="mr-amenities">
            <% amenities.forEach(function (am) { %>
              <span class="mr-amenity"><%- chk %><%= am %></span>
            <% }); %>
          </div>
          <div class="mr-pricing-row">
            <% if (hr > 0 && fd > 0) { %>
              <div class="mr-price-option">
                <div class="mr-price-label">Hourly</div>
                <div class="mr-price-value"><%= formatNgn(hr) %></div>
                <div class="mr-price-period">per hour</div>
              </div>
              <div class="mr-price-divider"></div>
              <div class="mr-price-option mr-price-option--second">
                <div class="mr-price-label">Full day</div>
                <div class="mr-price-value"><%= formatNgn(fd) %></div>
                <div class="mr-price-period">flat rate</div>
              </div>
            <% } else if (hr > 0) { %>
              <div class="mr-price-option">
                <div class="mr-price-label">From</div>
                <div class="mr-price-value"><%= formatNgn(hr) %></div>
                <div class="mr-price-period">per hour</div>
              </div>
            <% } else if (fd > 0) { %>
              <div class="mr-price-option">
                <div class="mr-price-label">Full day rate</div>
                <div class="mr-price-value"><%= formatNgn(fd) %></div>
                <div class="mr-price-period">flat rate / day</div>
              </div>
            <% } else { %>
              <div class="mr-price-option">
                <div class="mr-price-label">Pricing</div>
                <div class="mr-price-value">—</div>
                <div class="mr-price-period">See booking</div>
              </div>
            <% } %>
          </div>
        </div>
        <div class="mr-room-cta">
          <a class="mr-btn-book" href="/meeting-rooms/<%= r.id %>">
            Book this room
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M2 7h10M8 4l3 3-3 3"/></svg>
          </a>
        </div>
      </article>
    <% }); %>
  </div>
<% } %>

  <div class="portal-bottom-links">
    <a class="portal-bottom-link" href="/meeting-rooms/my-bookings">My room bookings</a>
    <span class="portal-bottom-sep">·</span>
    <a class="portal-bottom-link" href="/dashboard">Dashboard</a>
  </div>
</div>

<script>
(function () {
  var bar = document.querySelector('[data-mr-filters]');
  if (!bar) return;
  var chips = bar.querySelectorAll('.mr-filter-chip');
  var cards = document.querySelectorAll('[data-mr-card]');
  function apply(filter) {
    cards.forEach(function (card) {
      var show = filter === 'all' || card.getAttribute('data-mr-match-' + filter) === '1';
      card.style.display = show ? '' : 'none';
    });
  }
  chips.forEach(function (chip) {
    chip.addEventListener('click', function () {
      var f = chip.getAttribute('data-filter');
      chips.forEach(function (c) { c.classList.remove('active'); });
      chip.classList.add('active');
      apply(f || 'all');
    });
  });
})();
</script>
