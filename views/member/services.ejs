<div class="portal-page portal-page--services">
  <div class="portal-tabs">
    <a href="/services?tab=mine" class="portal-tab<%= tab === 'mine' ? ' is-active' : '' %>">My Services</a>
    <a href="/services?tab=request" class="portal-tab<%= tab === 'request' ? ' is-active' : '' %>">Request a Service</a>
  </div>

<% if (tab === 'mine') { %>
  <% if (!mine.length) { %>
    <div class="portal-panel portal-panel--empty">
      <p class="portal-panel-muted">No service requests yet</p>
      <p class="portal-panel-foot"><a href="/services?tab=request" class="portal-inline-link">Browse services</a></p>
    </div>
  <% } %>
  <% mine.forEach(function (r) { %>
    <a href="/services/<%= r.id %>" class="portal-service-link">
      <div class="portal-service-card">
        <div class="portal-service-card-head">
          <strong class="portal-service-name"><%= r.service_name %></strong>
          <span class="portal-pill"><%= r.status %></span>
          <% if (r.action_required_member) { %><span class="portal-pill portal-pill--warn">Action required</span><% } %>
        </div>
        <p class="portal-service-meta"><%= r.category_name %> · Requested <%= formatDateTime(r.created_at) %></p>
      </div>
    </a>
  <% }); %>
<% } else { %>
  <% cats.forEach(function (c, ci) { %>
    <div class="portal-section-head<%= ci === 0 ? ' portal-section-head--first' : '' %>">
      <h2 class="portal-section-title"><%= c.name %></h2>
      <% if (c.tagline) { %><p class="portal-section-tagline"><%= c.tagline %></p><% } %>
    </div>
    <% services.filter(function (s) { return s.category_id === c.id && s.booking_mode !== 'plan_booking'; }).forEach(function (s) { %>
      <div class="portal-request-card">
        <div class="portal-request-card-head">
          <strong class="portal-request-title"><%= s.name %></strong>
          <% var pc = Number(s.portal_price_cents || 0); %>
          <% if (pc > 0) { %>
            <span class="portal-price-tag"><%= formatNgn(pc) %></span>
          <% } else { %>
            <span class="portal-pill">Quote</span>
          <% } %>
        </div>
        <p class="portal-request-desc"><%= s.description %></p>
        <a class="portal-btn-primary" href="/services/request/<%= s.id %>">Request</a>
      </div>
    <% }); %>
  <% }); %>
<% } %>
</div>
