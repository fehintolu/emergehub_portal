<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> — EmergeHub Admin</title>
  <link rel="stylesheet" href="/css/member-portal.css?v=<%= typeof memberPortalCssV !== 'undefined' ? memberPortalCssV : '1' %>" />
</head>
<body>
  <%- include('../partials/admin-sidebar') %>

  <div class="main">
    <header class="page-header anim anim-1">
      <div>
        <div class="page-title"><%= title %></div>
        <div class="page-sub"><%= typeof pageSub === 'string' && pageSub ? pageSub : 'Portal administration' %></div>
      </div>
    </header>

    <div class="member-body">
      <%- body %>
    </div>
  </div>
</body>
</html>
