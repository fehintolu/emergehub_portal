<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> — EmergeHub Portal</title>
  <link rel="stylesheet" href="/css/member-portal.css?v=<%= memberPortalCssV %>" />
</head>
<body>
  <%- include('../partials/member-sidebar') %>

  <% var mp = typeof memberPath !== 'undefined' ? String(memberPath) : ''; %>
  <% var _theme = mp === '/workspace' || mp.indexOf('/meeting-rooms') === 0 || mp.indexOf('/billing') === 0 || mp === '/services' || mp.indexOf('/services/') === 0; %>
  <% var _workspaceOnly = mp === '/workspace'; %>
  <% var _svcDetail = typeof headerVariant !== 'undefined' && headerVariant === 'service-detail'; %>
  <div class="main<%= _theme ? ' main--portal-theme' : '' %>">
    <% if (_svcDetail) { %>
    <header class="page-header anim anim-1 portal-topbar sr-detail-header">
      <div class="sr-breadcrumb-row">
        <a href="<%= typeof breadcrumbBack === 'string' ? breadcrumbBack : '/services?tab=mine' %>" class="sr-breadcrumb-back" aria-label="Back to services">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M9 2L4 7l5 5"/></svg>
        </a>
        <div class="sr-breadcrumb-path">
          <% if (typeof breadcrumbItems !== 'undefined' && breadcrumbItems && breadcrumbItems.length) { %>
            <% breadcrumbItems.forEach(function (bc, i) { %>
              <% if (i < breadcrumbItems.length - 1) { %>
                <a href="<%= bc.href %>" class="sr-breadcrumb-link"><%= bc.label %></a>
                <span class="sr-breadcrumb-sep">›</span>
              <% } else { %>
                <span class="sr-breadcrumb-current"><%= bc.label %></span>
              <% } %>
            <% }); %>
          <% } %>
        </div>
      </div>
      <div class="header-toolbar topbar-actions">
        <a class="icon-btn" href="/services?tab=request" title="Browse services" aria-label="Browse services">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><circle cx="7" cy="7" r="4.5"/><path d="M11 11l2.5 2.5"/></svg>
        </a>
        <a class="icon-btn" href="/notifications" title="Notifications" aria-label="Notifications">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M8 2a4 4 0 0 1 4 4v2l1 2H3l1-2V6a4 4 0 0 1 4-4zM6.5 12a1.5 1.5 0 0 0 3 0"/></svg>
          <% if (typeof notifCount === 'number' && notifCount > 0) { %>
            <span class="notif-dot" aria-hidden="true"></span>
          <% } %>
        </a>
      </div>
    </header>
    <% } else { %>
    <header class="page-header anim anim-1<%= _theme ? ' portal-topbar' : '' %>">
      <div class="page-header-mini">
        <div class="page-title<%= _theme ? ' portal-page-title' : '' %>"><%= title %></div>
        <div class="page-sub"><%= typeof pageSub === 'string' && pageSub ? pageSub : (typeof todaySubtitle !== 'undefined' ? todaySubtitle : '') %></div>
      </div>
      <div class="header-toolbar topbar-actions">
        <% if (_workspaceOnly) { %>
        <a class="icon-btn" href="/meeting-rooms" title="Search" aria-label="Book a meeting room">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><circle cx="7" cy="7" r="4.5"/><path d="M11 11l2.5 2.5"/></svg>
        </a>
        <% } else { %>
        <a class="icon-btn" href="/services?tab=request" title="Browse services" aria-label="Browse services">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        </a>
        <% } %>
        <a class="icon-btn" href="/notifications" title="Notifications" aria-label="Notifications">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M8 2a4 4 0 0 1 4 4v2l1 2H3l1-2V6a4 4 0 0 1 4-4zM6.5 12a1.5 1.5 0 0 0 3 0"/></svg>
          <% if (typeof notifCount === 'number' && notifCount > 0) { %>
            <span class="notif-dot" aria-hidden="true"></span>
          <% } %>
        </a>
      </div>
    </header>
    <% } %>

    <div class="member-body<%= _theme ? ' member-body--portal-theme' : '' %><%= _svcDetail ? ' member-body--sr-detail' : '' %>">
      <%- body %>
    </div>
  </div>
</body>
</html>
