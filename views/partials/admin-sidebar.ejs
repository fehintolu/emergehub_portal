<% var ap = typeof adminPath !== 'undefined' && adminPath ? String(adminPath) : ''; %>
<aside class="sidebar">
  <div class="sidebar-logo">
    <a href="/admin">
      <div class="logo-icon">E</div>
      <div class="logo-text">Emerge<span>Hub</span></div>
    </a>
  </div>

  <nav class="sidebar-nav">
    <a href="/admin" class="nav-item <%= ap === '/' ? 'active' : '' %>">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
      Dashboard
    </a>
    <a href="/admin/members" class="nav-item <%= ap.indexOf('/members') === 0 ? 'active' : '' %>">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
      Members
    </a>
    <a href="/admin/catalog" class="nav-item <%= ap.indexOf('/catalog') === 0 ? 'active' : '' %>">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="3"/><path d="M19.07 4.93a10 10 0 010 14.14M4.93 4.93a10 10 0 000 14.14"/></svg>
      Workspace services
    </a>
    <a href="/admin/space-utilization" class="nav-item <%= ap.indexOf('/space-utilization') === 0 || ap.indexOf('/capacity/') === 0 ? 'active' : '' %>">
      Space utilization
    </a>
    <a href="/admin/service-requests" class="nav-item <%= ap.indexOf('/service-requests') === 0 ? 'active' : '' %>">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
      Service requests
    </a>
    <div class="nav-label">Finance</div>
    <a href="/admin/invoices" class="nav-item <%= ap.indexOf('/invoices') === 0 ? 'active' : '' %>">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg>
      Invoices
    </a>
    <div class="nav-label">Meeting rooms</div>
    <a href="/admin/meeting-rooms" class="nav-item <%= ap === '/meeting-rooms' ? 'active' : '' %>">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
      Hub
    </a>
    <a href="/admin/meeting-rooms/rooms" class="nav-item <%= ap.indexOf('/meeting-rooms/rooms') === 0 ? 'active' : '' %>">Rooms</a>
    <a href="/admin/meeting-rooms/calendar" class="nav-item <%= ap.indexOf('/meeting-rooms/calendar') === 0 ? 'active' : '' %>">Calendar</a>
    <a href="/admin/meeting-rooms/bookings" class="nav-item <%= ap.indexOf('/meeting-rooms/bookings') === 0 ? 'active' : '' %>">Bookings</a>
    <a href="/admin/meeting-rooms/discount-tiers" class="nav-item <%= ap.indexOf('/meeting-rooms/discount-tiers') === 0 ? 'active' : '' %>">Discount tiers</a>
    <a href="/admin/rooms/legacy" class="nav-item <%= ap.indexOf('/rooms/legacy') === 0 ? 'active' : '' %>">Legacy requests</a>
    <div class="nav-label">Operations</div>
    <a href="/admin/documents" class="nav-item <%= ap.indexOf('/documents') === 0 ? 'active' : '' %>">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
      Documents
    </a>
    <a href="/admin/support" class="nav-item <%= ap.indexOf('/support') === 0 ? 'active' : '' %>">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
      Support
    </a>
    <a href="/admin/notifications" class="nav-item <%= ap.indexOf('/notifications') === 0 ? 'active' : '' %>">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 01-3.46 0"/></svg>
      Notifications
    </a>
    <a href="/admin/settings" class="nav-item <%= ap.indexOf('/settings') === 0 ? 'active' : '' %>">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z"/></svg>
      Settings
    </a>
  </nav>

  <div class="sidebar-footer">
    <div class="sidebar-user" style="cursor:default;">
      <div class="logo-icon" style="font-size:11px;"><%= (currentAdmin && currentAdmin.username) ? String(currentAdmin.username).slice(0, 2).toUpperCase() : 'A' %></div>
      <div>
        <div class="user-name"><%= currentAdmin && currentAdmin.username ? currentAdmin.username : 'Admin' %></div>
        <div class="user-role">Administrator</div>
      </div>
    </div>
    <form method="post" action="/admin/logout">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <button type="submit" class="logout-btn">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
        Log out
      </button>
    </form>
  </div>
</aside>
