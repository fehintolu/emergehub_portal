<p class="page-lead anim anim-1" style="margin-top:0;">
  <a href="/admin" class="section-link">← Dashboard</a>
</p>
<% if (query && query.err) { %>
  <div class="alert alert-error anim anim-1">Could not complete that action.</div>
<% } %>
<% if (query && query.msg) { %>
  <div class="alert alert-success anim anim-1">Saved.</div>
<% } %>

<div class="card anim anim-1" style="margin-bottom:20px;">
  <div class="section-header">
    <span class="section-title">Physical units (seat grid)</span>
  </div>
  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:14px;">
    <div><span class="stat-label">Total units</span><div class="stat-value" style="font-size:22px;"><%= summary.total_units %></div></div>
    <div><span class="stat-label">Occupied</span><div class="stat-value" style="font-size:22px;"><%= summary.occupied_units %></div></div>
    <div><span class="stat-label">Available</span><div class="stat-value" style="font-size:22px;"><%= summary.available_units %></div></div>
    <div><span class="stat-label">Maintenance</span><div class="stat-value" style="font-size:22px;"><%= summary.maintenance_units %></div></div>
    <div><span class="stat-label">Paid, not assigned seat</span><div class="stat-value" style="font-size:22px;"><%= unassignedPaid %></div></div>
  </div>
  <p class="page-lead" style="margin:12px 0 0;font-size:13px;color:var(--text-secondary);">Seat-level tracking applies to <strong>capacity-limited</strong> catalogue plans. Add unit rows under each profile, then assign members.</p>
</div>

<% if (capacityPlansMissingProfile && capacityPlansMissingProfile.length) { %>
  <div class="card anim anim-2" style="margin-bottom:20px;border-color:var(--orange);">
    <div class="section-header">
      <span class="section-title">Capacity-limited plans — needs profile</span>
    </div>
    <p class="page-lead" style="margin:0 0 10px;">These plans are marked capacity-limited but have no capacity profile yet. Set <strong>Seat capacity</strong> on the plan in <a href="/admin/catalog">Catalogue → plans</a> (or create a profile below).</p>
    <ul class="plain-list" style="margin:0;">
      <% capacityPlansMissingProfile.forEach(function (row) { %>
        <li><strong><%= row.service_name %></strong> — <%= row.plan_title %></li>
      <% }); %>
    </ul>
  </div>
<% } %>

<div class="card anim anim-2" style="margin-bottom:20px;">
  <div class="section-header">
    <span class="section-title">Active plans — not seat-managed</span>
  </div>
  <p class="page-lead" style="margin:0 0 12px;">Unlimited / non–capacity-limited workspace plans (no physical seat grid). Shows members with a paid request still in progress or completed touchpoints.</p>
  <% if (!nonCapacityPlans.length) { %>
    <p class="page-lead" style="margin:0;">No active non–capacity-limited plans.</p>
  <% } else { %>
    <div style="overflow-x:auto;">
      <table class="sub-table">
        <thead>
          <tr>
            <th>Service</th>
            <th>Plan</th>
            <th style="text-align:right">Price</th>
            <th style="text-align:right">Paid activity (members)</th>
          </tr>
        </thead>
        <tbody>
          <% nonCapacityPlans.forEach(function (r) { %>
            <tr>
              <td><%= r.service_name %></td>
              <td><%= r.plan_title %></td>
              <td style="text-align:right"><%= formatNgn(r.price_cents) %></td>
              <td style="text-align:right"><%= r.paid_member_touchpoints %></td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>

<div class="section-header" style="margin:24px 0 12px;">
  <span class="section-title">Capacity-limited plans (profiles)</span>
</div>
<div class="member-two-col">
  <% profiles.forEach(function (p) { %>
    <% var cap = Number(p.total_units) || 0; var occ = Number(p.occ_units) || 0; var pct = cap > 0 ? Math.round((occ / cap) * 100) : 0; %>
    <% var barClass = pct >= 95 ? 'util-bar--hot' : pct >= 75 ? 'util-bar--amber' : 'util-bar--ok'; %>
    <div class="card anim anim-2">
      <div class="section-header">
        <span class="section-title"><%= p.service_name || 'Service' %> — <%= p.plan_title || 'Plan' %></span>
        <a class="section-link" href="/admin/capacity/profiles/<%= p.id %>">Manage units</a>
      </div>
      <p class="page-lead" style="margin:0 0 10px;">Occupied <strong><%= occ %></strong> of <strong><%= cap %></strong> configured seats · <%= p.unit_rows %> unit rows · Waitlist <strong><%= p.waitlist_count != null ? p.waitlist_count : 0 %></strong></p>
      <div class="util-bar <%= barClass %>"><span style="width:<%= Math.min(100, pct) %>%;"></span></div>
      <p class="page-lead" style="margin:8px 0 0;font-size:12px;">Auto-assign: <%= p.auto_assign ? 'on' : 'off' %> · Waitlist: <%= p.waitlist_enabled ? 'on' : 'off' %></p>
    </div>
  <% }); %>
</div>

<% if (!profiles.length) { %>
  <div class="card anim anim-2"><p class="page-lead" style="margin:0;">No capacity profiles yet. Mark a plan as capacity-limited in <strong>Catalogue → plans</strong> and set seat count, or link a profile below.</p></div>
<% } %>

<div class="card anim anim-3" style="margin-top:24px;">
  <div class="section-header">
    <span class="section-title">Recent seat assignments</span>
  </div>
  <% if (!recentAssignments.length) { %>
    <p class="page-lead" style="margin:0;">No assignment rows yet.</p>
  <% } else { %>
    <div style="overflow-x:auto;">
      <table class="sub-table">
        <thead>
          <tr>
            <th>Member</th>
            <th>Plan</th>
            <th>Unit</th>
            <th>Start</th>
            <th>End</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody>
          <% recentAssignments.forEach(function (a) { %>
            <tr>
              <td><%= a.member_name %><br/><small style="opacity:0.8"><%= a.member_email %></small></td>
              <td><%= a.service_name || '' %> — <%= a.plan_title || '' %></td>
              <td><%= a.unit_label %></td>
              <td><%= formatDate(a.started_at) %></td>
              <td><%= a.ends_at ? formatDate(a.ends_at) : '—' %></td>
              <td><%= a.ended_at ? 'Ended' : 'Active' %></td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>

<div class="card anim anim-3" style="margin-top:24px;">
  <div class="section-header">
    <span class="section-title">Next 30 days — dated assignments (headcount)</span>
  </div>
  <p class="page-lead" style="margin:0 0 10px;font-size:13px;">Assignments with an end date active on each day (ongoing / open-ended are excluded).</p>
  <div style="overflow-x:auto;">
    <table class="sub-table">
      <thead><tr><th>Date</th><th>Active with end date</th></tr></thead>
      <tbody>
        <% projection.forEach(function (row) { %>
          <tr><td><%= formatDate(row.d) %></td><td><%= row.assigned %></td></tr>
        <% }); %>
      </tbody>
    </table>
  </div>
</div>

<div class="card anim anim-3" style="margin-top:24px;">
  <div class="section-header">
    <span class="section-title">Link capacity profile to a plan (advanced)</span>
  </div>
  <p class="page-lead">Prefer setting <strong>Seat capacity</strong> on the plan in Catalogue — that creates the profile automatically. Use this if you need a manual link by plan UUID.</p>
  <form method="post" action="/admin/capacity/profiles" class="form-row" style="display:flex;flex-wrap:wrap;gap:12px;align-items:flex-end;">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
    <div><label>service_plan_id (uuid)</label><input name="service_plan_id" required placeholder="uuid" style="width:280px;" /></div>
    <div><label>Total seat slots</label><input type="number" name="total_units" min="0" value="0" style="width:100px;" /></div>
    <div><label><input type="checkbox" name="auto_assign" value="1" /> Auto-assign on payment</label></div>
    <div><label><input type="checkbox" name="waitlist_enabled" value="1" checked /> Waitlist enabled</label></div>
    <button type="submit" class="btn btn-primary">Create profile</button>
  </form>
</div>

<style>
.util-bar { height: 10px; border-radius: 6px; background: var(--border); overflow: hidden; }
.util-bar > span { display: block; height: 100%; border-radius: 6px; transition: width 0.2s ease; }
.util-bar--ok > span { background: var(--green); }
.util-bar--amber > span { background: var(--orange); }
.util-bar--hot > span { background: var(--red); }
</style>
