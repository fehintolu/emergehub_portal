<div class="table-wrap">
  <table class="data">
    <thead><tr><th>Member</th><th>File</th><th>Type</th><th>Date</th><th></th></tr></thead>
    <tbody>
      <% rows.forEach(function (d) { %>
        <tr>
          <td><%= d.full_name %></td>
          <td><a href="/admin/documents/download/<%= d.id %>"><%= d.original_name %></a></td>
          <td><%= d.mime_type %></td>
          <td><%= formatDateTime(d.created_at) %></td>
          <td>
            <form method="post" action="/admin/documents/<%= d.id %>/delete" onsubmit="return confirm('Delete?');" style="display:inline;">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
              <button type="submit" class="link-btn">Delete</button>
            </form>
          </td>
        </tr>
      <% }); %>
    </tbody>
  </table>
</div>
