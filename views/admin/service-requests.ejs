<form method="get" style="margin-bottom:1rem;">
  <select name="status" onchange="this.form.submit()">
    <option value="">All statuses</option>
    <% ['Submitted','Under Review','In Progress','Action Required','Completed','Cancelled'].forEach(function (s) { %>
      <option value="<%= s %>" <%= typeof query !== 'undefined' && query.status === s ? 'selected' : '' %>><%= s %></option>
    <% }); %>
  </select>
</form>
<div class="table-wrap">
  <table class="data">
    <thead><tr><th>Date</th><th>Member</th><th>Service</th><th>Status</th></tr></thead>
    <tbody>
      <% rows.forEach(function (r) { %>
        <tr>
          <td><%= formatDateTime(r.created_at) %></td>
          <td><%= r.full_name %></td>
          <td><a href="/admin/service-requests/<%= r.id %>"><%= r.service_name %></a></td>
          <td><%= r.status %></td>
        </tr>
      <% }); %>
    </tbody>
  </table>
</div>
