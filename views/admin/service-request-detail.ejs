<p class="page-lead anim anim-2" style="margin-top:0;">
  <a href="/admin/members/<%= sr.member_id %>" class="section-link"><%= sr.member_name %></a>
  · <%= sr.member_email %>
</p>

<% if (typeof query !== 'undefined' && query.msg === 'inv') { %>
  <div class="alert alert-success anim anim-2">Invoice created and the member was notified.</div>
<% } %>
<% if (typeof query !== 'undefined' && query.err === 'inv') { %>
    <div class="alert alert-error anim anim-2">Could not create invoice — check amount and description.</div>
<% } %>
<% if (typeof query !== 'undefined' && query.err === 'complete_date') { %>
  <div class="alert alert-error anim anim-2">Completed status requires valid service start and end dates (end on or after start).</div>
<% } %>

<div class="card anim anim-2">
  <div style="display:flex;flex-wrap:wrap;align-items:center;gap:10px;">
    <h2 class="page-title" style="margin:0;font-size:1.25rem;"><%= sr.service_name %></h2>
    <span class="badge"><%= sr.status %></span>
  </div>
  <p style="margin:12px 0 0;color:var(--text-secondary);font-size:14px;line-height:1.5;"><%= sr.description %></p>
  <p style="margin:10px 0 0;font-size:13px;color:var(--text-secondary);">Phone: <%= sr.member_phone || '—' %></p>
</div>

<% if (sr.access_started_at || sr.access_ends_at) { %>
  <div class="card anim anim-2" style="border-left:4px solid var(--green);">
    <h3 style="margin-top:0;">Access window</h3>
    <p class="page-lead" style="margin:0;"><strong>From</strong> <%= formatDateTime(sr.access_started_at) %> <strong>to</strong> <%= formatDateTime(sr.access_ends_at) %></p>
  </div>
<% } %>

<div class="card anim anim-3" style="border-left:4px solid var(--accent);">
  <h3 style="margin-top:0;">Invoices</h3>
  <% if (!requestInvoices || !requestInvoices.length) { %>
    <p class="page-lead" style="margin:0;">None yet.</p>
  <% } else { %>
    <ul class="plain-list">
      <% requestInvoices.forEach(function (inv) { %>
        <li>
          <strong><%= inv.invoice_number %></strong> · <%= formatNgn(inv.total_cents) %> · Due <%= formatDate(inv.due_date) %>
          · <span class="badge"><%= inv.status %></span>
          · <a href="/admin/invoices/<%= inv.id %>" class="section-link">Open</a>
        </li>
      <% }); %>
    </ul>
  <% } %>
  <h4 style="margin:20px 0 10px;">Generate invoice</h4>
  <p class="page-lead" style="margin-bottom:12px;">Creates a new invoice linked to this request (member sees it on the request and in Billing).</p>
  <form method="post" action="/admin/service-requests/<%= sr.id %>/generate-invoice">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
    <div class="form-row">
      <label>Line description</label>
      <input type="text" name="line_desc" required placeholder="e.g. Additional fit-out deposit" />
    </div>
    <div class="form-row">
      <label>Amount (₦)</label>
      <input type="number" name="amount_ngn" min="1" step="1" required />
    </div>
    <div class="form-row">
      <label>Due in (days)</label>
      <input type="number" name="due_days" min="1" max="90" value="7" />
    </div>
    <button type="submit" class="btn btn-primary">Create invoice</button>
  </form>
</div>

<div class="two-col anim anim-3" style="margin-top:8px;">
  <div class="col-left card">
    <h3>Status</h3>
    <form method="post" action="/admin/service-requests/<%= sr.id %>/status" id="status-form">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <div class="form-row">
        <label>Workflow</label>
        <select name="status" id="status-select">
          <% ['Submitted','Under Review','In Progress','Action Required','Completed','Cancelled'].forEach(function (st) { %>
            <option value="<%= st %>" <%= sr.status === st ? 'selected' : '' %>><%= st %></option>
          <% }); %>
        </select>
      </div>
      <div class="form-row" id="complete-dates" style="display:none;">
        <label>Service start (date)</label>
        <input type="date" name="service_start_date" value="<%= sr.service_start_date ? String(sr.service_start_date).slice(0,10) : '' %>" />
      </div>
      <div class="form-row" id="complete-dates-end" style="display:none;">
        <label>Service end (date)</label>
        <input type="date" name="service_end_date" value="<%= sr.service_end_date ? String(sr.service_end_date).slice(0,10) : '' %>" />
      </div>
      <div class="form-row">
        <label><input type="checkbox" name="action_required" value="1" <%= sr.action_required_member ? 'checked' : '' %> /> Member action required</label>
      </div>
      <div class="form-row">
        <label>Note to member (timeline)</label>
        <textarea name="note" rows="3" placeholder="Optional note shown on the member timeline"></textarea>
      </div>
      <button type="submit" class="btn btn-primary">Update status</button>
    </form>
    <script>
    (function () {
      var sel = document.getElementById('status-select');
      var b1 = document.getElementById('complete-dates');
      var b2 = document.getElementById('complete-dates-end');
      function sync() {
        var on = sel && sel.value === 'Completed';
        if (b1) b1.style.display = on ? 'block' : 'none';
        if (b2) b2.style.display = on ? 'block' : 'none';
      }
      if (sel) { sel.addEventListener('change', sync); sync(); }
    })();
    </script>
  </div>
  <div class="col-right card">
    <h3>Assign</h3>
    <form method="post" action="/admin/service-requests/<%= sr.id %>/assign">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <div class="form-row">
        <label>Admin</label>
        <select name="admin_id">
          <option value="">—</option>
          <% admins.forEach(function (a) { %>
            <option value="<%= a.id %>" <%= sr.assigned_admin_id === a.id ? 'selected' : '' %>><%= a.username %></option>
          <% }); %>
        </select>
      </div>
      <button type="submit" class="btn btn-secondary">Save assignment</button>
    </form>
  </div>
</div>

<div class="card anim anim-4">
  <h3>Timeline</h3>
  <ul class="plain-list">
    <% updates.forEach(function (u) { %>
      <li><%= formatDateTime(u.created_at) %> — <strong><%= u.stage %></strong><% if (u.note) { %>: <%= u.note %><% } %></li>
    <% }); %>
  </ul>
</div>

<div class="card anim anim-4">
  <h3>Messages</h3>
  <% msgs.forEach(function (m) { %>
    <div class="card" style="background:var(--surface-2);margin-bottom:12px;">
      <small style="color:var(--text-secondary);"><%= m.sender_type %></small>
      <p style="margin-top:8px;"><%= m.body %></p>
    </div>
  <% }); %>
  <form method="post" action="/admin/service-requests/<%= sr.id %>/message" style="margin-top:16px;">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
    <div class="form-row"><label>Message member</label><textarea name="body" required rows="3"></textarea></div>
    <button type="submit" class="btn btn-primary">Send to member</button>
  </form>
</div>

<div class="card anim anim-4">
  <h3>Files</h3>
  <% if (!docs.length) { %><p class="page-lead" style="margin:0;">None attached.</p><% } %>
  <ul class="plain-list">
    <% docs.forEach(function (d) { %>
      <li><a href="/admin/documents/download/<%= d.id %>"><%= d.original_name %></a></li>
    <% }); %>
  </ul>
</div>
