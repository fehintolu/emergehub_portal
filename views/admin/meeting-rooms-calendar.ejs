<p class="page-lead"><a href="/admin/meeting-rooms">← Hub</a> · Timezone: <strong><%= portalTz %></strong></p>
<form method="get" class="card" style="margin-bottom:16px;display:flex;flex-wrap:wrap;gap:12px;align-items:flex-end;">
  <div class="form-row" style="margin:0;">
    <label>Year</label>
    <input type="number" name="year" value="<%= y %>" />
  </div>
  <div class="form-row" style="margin:0;">
    <label>Month</label>
    <input type="number" name="month" min="1" max="12" value="<%= m %>" />
  </div>
  <div class="form-row" style="margin:0;">
    <label>Room</label>
    <select name="room_id">
      <option value="">All rooms</option>
      <% rooms.forEach(function (r) { %>
        <option value="<%= r.id %>" <%= String(roomId) === String(r.id) ? 'selected' : '' %>><%= r.name %></option>
      <% }); %>
    </select>
  </div>
  <button type="submit" class="btn btn-primary">Go</button>
</form>

<div class="card">
  <div style="display:grid;grid-template-columns:repeat(7,1fr);gap:4px;font-weight:600;font-size:13px;margin-bottom:4px;">
    <% ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'].forEach(function (d) { %><div style="padding:6px;"><%= d %></div><% }); %>
  </div>
  <div style="display:grid;grid-template-columns:repeat(7,1fr);gap:4px;">
    <% cells.forEach(function (c) { %>
      <% if (c.empty) { %>
        <div style="min-height:72px;background:#f5f5f5;border-radius:6px;"></div>
      <% } else { %>
        <div style="min-height:72px;border:1px solid rgba(0,0,0,0.08);border-radius:6px;padding:6px;font-size:12px;">
          <div style="font-weight:700;margin-bottom:4px;"><%= c.day %></div>
          <% if (c.bookings.length === 0) { %>
            <span style="opacity:0.5;">—</span>
          <% } else { %>
            <% c.bookings.slice(0, 3).forEach(function (b) { %>
              <div style="margin-bottom:4px;line-height:1.3;">
                <span style="opacity:0.75;"><%= b.room_name %></span><br/>
                <%= formatDateTime(b.starts_at).split(',')[1] || formatDateTime(b.starts_at) %>
                <span style="opacity:0.7;">(<%= b.status %>)</span>
              </div>
            <% }); %>
            <% if (c.bookings.length > 3) { %><div>+<%= c.bookings.length - 3 %> more</div><% } %>
          <% } %>
        </div>
      <% } %>
    <% }); %>
  </div>
</div>
<p><a href="/admin/meeting-rooms/calendar.json?from=<%= y %>-<%= String(m).padStart(2,'0') %>-01T00:00:00&to=<%= y %>-<%= String(m).padStart(2,'0') %>-15T00:00:00<%= roomId ? '&room_id=' + encodeURIComponent(roomId) : '' %>">Sample JSON feed</a> (adjust dates as needed)</p>
