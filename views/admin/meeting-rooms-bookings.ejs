<p class="page-lead"><a href="/admin/meeting-rooms">← Hub</a></p>
<% if (typeof query !== 'undefined' && query.msg === 'manual') { %><div class="alert alert-success">Manual booking created (confirmed, no invoice).</div><% } %>
<% if (typeof query !== 'undefined' && query.msg === 'manualinv') { %><div class="alert alert-success">Manual booking created with invoice (pending payment).</div><% } %>
<% if (typeof query !== 'undefined' && query.err === 'slot') { %><div class="alert alert-error">Slot not available (overlap, block, or hours).</div><% } %>
<% if (typeof query !== 'undefined' && query.err === 'norooms') { %><div class="alert alert-error">No active meeting rooms. Add a room first.</div><% } %>
<% if (typeof query !== 'undefined' && query.err === 'room') { %><div class="alert alert-error">Room not found or inactive.</div><% } %>

<form method="get" class="card" style="margin-bottom:16px;display:flex;flex-wrap:wrap;gap:12px;align-items:flex-end;">
  <div class="form-row" style="margin:0;">
    <label>Status</label>
    <select name="status">
      <option value="">Any</option>
      <% ['pending_payment','confirmed','cancelled','expired','completed'].forEach(function (s) { %>
        <option value="<%= s %>" <%= filters.status === s ? 'selected' : '' %>><%= s %></option>
      <% }); %>
    </select>
  </div>
  <div class="form-row" style="margin:0;">
    <label>Room</label>
    <select name="room_id">
      <option value="">Any</option>
      <% rooms.forEach(function (r) { %>
        <option value="<%= r.id %>" <%= String(filters.room_id) === String(r.id) ? 'selected' : '' %>><%= r.name %></option>
      <% }); %>
    </select>
  </div>
  <button type="submit" class="btn btn-primary">Filter</button>
</form>

<div class="card" style="margin-bottom:20px;">
  <h3 style="margin-top:0;">New booking</h3>
  <p class="page-lead">Use the <strong>same calendar and time picker</strong> as members (month grid, 30-minute timeline, tier pricing, plan credits in the estimate). You choose the member and whether to invoice.</p>
  <p style="margin:0;">
    <a class="btn btn-primary" href="/admin/meeting-rooms/bookings/new<%= typeof prefillMemberId !== 'undefined' && prefillMemberId ? ('?member_id=' + encodeURIComponent(prefillMemberId)) : '' %>">Open booking calendar</a>
  </p>
</div>

<div class="card">
  <h3 style="margin-top:0;">Recent bookings</h3>
  <% if (!rows.length) { %><p style="margin:0;">No rows.</p><% } else { %>
    <table style="width:100%;border-collapse:collapse;font-size:14px;">
      <thead>
        <tr>
          <th style="text-align:left;padding:6px;">Room</th>
          <th style="text-align:left;padding:6px;">Member</th>
          <th style="text-align:left;padding:6px;">When</th>
          <th style="text-align:left;padding:6px;">Status</th>
          <th style="text-align:right;padding:6px;">Total</th>
          <th style="text-align:left;padding:6px;">Ref</th>
        </tr>
      </thead>
      <tbody>
        <% rows.forEach(function (r) { %>
          <tr>
            <td style="padding:6px;vertical-align:top;"><%= r.room_name %></td>
            <td style="padding:6px;vertical-align:top;"><%= r.full_name || '—' %><br/><small style="opacity:0.75;"><%= r.email || '' %></small></td>
            <td style="padding:6px;vertical-align:top;"><%= formatDateTime(r.starts_at) %></td>
            <td style="padding:6px;vertical-align:top;"><%= r.status %></td>
            <td style="padding:6px;vertical-align:top;text-align:right;"><%= formatNgn(r.total_cents) %></td>
            <td style="padding:6px;vertical-align:top;"><code style="font-size:12px;"><%= r.booking_reference %></code></td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  <% } %>
</div>
