<h2 style="margin-top:0;">Set a new password</h2>
<% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>
<% if (token) { %>
<form method="post" action="/admin/reset-password">
  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
  <input type="hidden" name="token" value="<%= token %>" />
  <div class="form-row"><label>New password</label><input type="password" name="password" minlength="8" required autocomplete="new-password" /></div>
  <div class="form-row"><label>Confirm</label><input type="password" name="password2" minlength="8" required autocomplete="new-password" /></div>
  <button type="submit" class="btn btn-primary">Save password</button>
</form>
<% } %>
<p style="margin-top:1rem;"><small><a href="/admin/forgot-password">Request a new link</a> · <a href="/admin/login">Sign in</a></small></p>
