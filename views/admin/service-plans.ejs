<% 
  function accessLabel(p) {
    if (p.duration_value && p.duration_unit) return p.duration_value + ' ' + p.duration_unit;
    return '—';
  }
%>
<div class="admin-plans">
  <div class="pl-topbar">
    <div class="pl-breadcrumb">
      <a class="pl-back" href="/admin/catalog" title="Catalogue" aria-label="Back">
        <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M8 2L4 6l4 4"/></svg>
      </a>
      <div class="pl-bc-path">
        <a class="pl-bc-link" href="/admin/catalog">Catalogue</a>
        <span class="pl-bc-sep">›</span>
        <a class="pl-bc-link" href="/admin/catalog/<%= svc.id %>/edit"><%= svc.name %></a>
        <span class="pl-bc-sep">›</span>
        <span class="pl-bc-current">Plans</span>
      </div>
    </div>
    <div style="display:flex;flex-wrap:wrap;gap:10px;align-items:center;">
      <a class="pl-btn-ghost" href="/admin/catalog/<%= svc.id %>/plans/archived" style="text-decoration:none;border:1px solid var(--border-strong);border-radius:8px;padding:8px 12px;font-size:13px;font-weight:600;color:var(--text-secondary);">Archived plans</a>
      <% if (typeof canMutate !== 'undefined' && canMutate) { %>
      <a class="pl-btn-primary" href="/admin/catalog/<%= svc.id %>/plans/new">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 2v10M2 7h10"/></svg>
        New plan
      </a>
      <% } %>
    </div>
  </div>

  <div class="pl-hero">
    <h1 class="pl-title">Workspace plans</h1>
    <p class="pl-lead"><%= svc.category_name %> · Prices and access rules members see on <strong>My workspace</strong>.</p>
  </div>

  <% if (svc.booking_mode !== 'plan_booking') { %>
    <div class="pl-alert pl-alert--warn">
      This service is in <strong>request</strong> mode. Switch to <strong>Bookable on My workspace</strong> under <a href="/admin/catalog/<%= svc.id %>/edit">Edit service</a> so members can choose a plan.
    </div>
  <% } %>

  <% if (msg === 'created') { %><div class="pl-alert pl-alert--ok">Plan added.</div><% } %>
  <% if (msg === 'updated') { %><div class="pl-alert pl-alert--ok">Plan saved.</div><% } %>
  <% if (msg === 'archived' || msg === 'deleted') { %><div class="pl-alert pl-alert--ok">Plan archived — find it under Archived plans.</div><% } %>
  <% if (err === '1') { %><div class="pl-alert pl-alert--err">Title is required.</div><% } %>

  <% if (!plans.length) { %>
    <div class="pl-empty">
      <p>No plans yet. Create one to offer a priced option for this service.</p>
      <% if (typeof canMutate !== 'undefined' && canMutate) { %>
      <a class="pl-btn-primary" href="/admin/catalog/<%= svc.id %>/plans/new">Create first plan</a>
      <% } %>
    </div>
  <% } else { %>
    <div class="pl-table-wrap">
      <table class="pl-table">
        <thead>
          <tr>
            <th>Plan</th>
            <th>Price</th>
            <th>Access window</th>
            <th>Meeting credits</th>
            <th>Capacity</th>
            <th>Status</th>
            <th class="pl-th-num">Sort</th>
            <th class="pl-th-actions"></th>
          </tr>
        </thead>
        <tbody>
          <% plans.forEach(function (p) { %>
            <tr>
              <td>
                <div class="pl-cell-title"><%= p.title %></div>
                <% var d = String(p.description || '').trim(); if (d) { %>
                  <div class="pl-cell-desc"><%= d.length > 100 ? d.slice(0, 100) + '…' : d %></div>
                <% } %>
              </td>
              <td class="pl-mono"><%= formatNgn(p.price_cents) %></td>
              <td><%= accessLabel(p) %></td>
              <td><%= Number(p.monthly_meeting_credit_minutes) || 0 %> min / mo<% if (p.weekly_access_sessions != null) { %><br/><span class="pl-muted"> <%= p.weekly_access_sessions %> sessions / wk</span><% } %></td>
              <td>
                <% if (p.is_capacity_limited) { %>
                  <span class="pl-pill pl-pill--cap"><%= Number(p.capacity_profile_total_units) || 0 %> seats</span>
                <% } else { %>
                  <span class="pl-muted">Not limited</span>
                <% } %>
              </td>
              <td>
                <% if (p.active) { %>
                  <span class="pl-pill pl-pill--live">Active</span>
                <% } else { %>
                  <span class="pl-pill pl-pill--off">Inactive</span>
                <% } %>
              </td>
              <td class="pl-num"><%= p.sort_order %></td>
              <td class="pl-actions">
                <% if (typeof canMutate !== 'undefined' && canMutate) { %>
                  <a class="pl-link-edit" href="/admin/catalog/<%= svc.id %>/plans/<%= p.id %>/edit">Edit</a>
                <% } else { %>
                  <span class="pl-muted">View-only</span>
                <% } %>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>
