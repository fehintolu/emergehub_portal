<h2 style="margin-top:0;">Set a new password</h2>
<% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>
<form method="post" action="/admin/change-password">
  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
  <div class="form-row"><label>New password</label><input type="password" name="password" minlength="8" required /></div>
  <div class="form-row"><label>Confirm</label><input type="password" name="password2" minlength="8" required /></div>
  <button type="submit" class="btn btn-primary">Save</button>
</form>
