<p><a class="btn btn-primary" href="/admin/invoices/new">Create invoice</a></p>
<form method="get" style="margin-bottom:1rem;">
  <select name="status" onchange="this.form.submit()">
    <option value="">All</option>
    <% ['draft','sent','unpaid','paid','overdue','awaiting_confirmation'].forEach(function (s) { %>
      <option value="<%= s %>" <%= typeof query !== 'undefined' && query.status === s ? 'selected' : '' %>><%= s %></option>
    <% }); %>
  </select>
</form>
<div class="table-wrap">
  <table class="data">
    <thead><tr><th>Invoice</th><th>Member</th><th>Amount</th><th>Due</th><th>Status</th></tr></thead>
    <tbody>
      <% rows.forEach(function (i) { %>
        <tr style="<%= i.status === 'overdue' ? 'background:#ffe8e8;' : '' %>">
          <td><a href="/admin/invoices/<%= i.id %>"><%= i.invoice_number %></a></td>
          <td><%= i.full_name %></td>
          <td><%= formatNgn(i.total_cents) %></td>
          <td><%= formatDate(i.due_date) %></td>
          <td><%= i.status %></td>
        </tr>
      <% }); %>
    </tbody>
  </table>
</div>
