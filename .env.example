HOST=127.0.0.1
PORT=4601
NODE_ENV=production
TRUST_PROXY=1
BASE_URL=https://my.emergehub.com.ng
DATABASE_URL=postgresql://USER:PASS@127.0.0.1:5432/emergehub_website

MEMBER_SESSION_SECRET=change-me-member-session-64-hex
ADMIN_SESSION_SECRET=change-me-admin-session-64-hex

COOKIE_SECURE=1

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=0
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@emergehub.com.ng

PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=

UPLOAD_DIR=/var/lib/emergehub-portal/uploads
MAX_UPLOAD_MB=10
